# ─────────────────────────────────────────────────────────────
# Bot Discord Z9 — copier ce fichier en « .env » et remplir.
# ⚠️ Ne JAMAIS committer le vrai .env (il contient le token du bot).
# ─────────────────────────────────────────────────────────────

# Identifiants du bot
DISCORD_TOKEN=            # le token du bot (Developer Portal > Bot > Reset Token) — SECRET
DISCORD_CLIENT_ID=1525157784109449297   # Application ID (public)
DISCORD_GUILD_ID=        # ID de ton serveur Z9

# IDs des salons
# (Discord > Paramètres > Avancés > Mode développeur ON, puis clic droit sur un salon > Copier l'identifiant)
CHANNEL_WELCOME=         # #bienvenue
CHANNEL_GOODBYE=         # #ciao
CHANNEL_TICKETS=         # #tickets
CHANNEL_REPORTS=         # #signalements
CHANNEL_SUGGESTIONS=     # #suggestion
CHANNEL_BONS_PLANS=      # #bons-plans
CHANNEL_LOGS=            # #logs
CHANNEL_CONTENU=         # #contenu-à-ajouter
